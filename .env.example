# --- Required credentials ---

# Anthropic API key - get one from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# CData Connect AI - your login email + a Personal Access Token created in
# the Connect AI UI under Settings -> Personal Access Tokens.
CDATA_EMAIL=you@yourcompany.com
CDATA_ACCESS_TOKEN=...


# --- Your CData connection names ---
# These match the connection names you chose when you created each CData
# Connect AI source. The benchmark scripts use them to build SQL paths and
# fetch the right tool surfaces. They are NEVER sent to Claude as input.
# See seed/load-*.md for setting up each source.

CDATA_ITSM_CATALOG=YourServiceNowConnection
CDATA_ITSM_SCHEMA=ServiceNow
CDATA_ITSM_TABLE=incident

CDATA_CRM_CATALOG=YourSalesforceConnection
CDATA_CRM_SCHEMA=Salesforce
CDATA_CRM_TABLE=Account

CDATA_WH_CATALOG=YourSnowflakeConnection
CDATA_WH_SCHEMA=SALESFORCE
CDATA_WH_TABLE=OPPORTUNITY


# --- Derived View name ---
# The name of the cross-source Derived View you create in Connect AI
# Data Explorer. See seed/derived_view.sql for the CREATE statement.
DERIVED_VIEW_NAME=BMK_Incident_Account_Revenue


# --- MCP endpoints ---
# MCP_GLOBAL_URL is the universal Connect AI MCP endpoint -- always the same.
# MCP_WORKSPACE_URL and MCP_TOOLKIT_URL are tenant-specific. Set them after
# you create a Workspace and a Toolkit in your tenant. Leave them blank to
# fall back to synthesised tool surfaces for those scenarios (the script
# still produces complete results, just using static count_tokens for the
# affected scenarios instead of live MCP calls).

MCP_GLOBAL_URL=https://mcp.cloud.cdata.com/mcp
# MCP_WORKSPACE_URL=https://mcp.cloud.cdata.com/mcp/workspaces/<your-workspace-uuid>
# MCP_TOOLKIT_URL=https://mcp.cloud.cdata.com/mcp/toolkits/<your-toolkit-uuid>
